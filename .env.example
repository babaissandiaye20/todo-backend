# Backend
PORT=4000
NODE_ENV=development

# MySQL credentials (used by docker-compose for both mysql and backend services)
MYSQL_USER=todo
MYSQL_PASSWORD=changeme
MYSQL_DATABASE=todo_db
MYSQL_ROOT_PASSWORD=changeme_root

# Prisma — points to the docker-compose service named "mysql".
# When running locally outside Docker, replace "mysql" host with "localhost".
DATABASE_URL="mysql://todo:changeme@mysql:3306/todo_db"
